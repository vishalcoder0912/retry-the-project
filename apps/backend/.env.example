NODE_ENV=development
PORT=3001
HOST=localhost
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

LOCAL_AI_ONLY=true
ENABLE_AI_FALLBACK=true
AI_PROVIDER_PRIORITY=ollama,gemini,openai,anthropic,openrouter,groq,mistral,deepseek,together,fireworks,perplexity,xai,cohere,azure_openai
AI_TIMEOUT_MS=120000
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9

MAIN_ANALYST_MODEL=qwen3:8b
DASHBOARD_PLANNER_MODEL=qwen3:8b
CHATBOT_MODEL=qwen3:8b
KPI_VALIDATOR_MODEL=qwen3:4b
CHART_VALIDATOR_MODEL=qwen3:4b
FACT_CHECKER_MODEL=qwen3:4b
JSON_VALIDATOR_MODEL=qwen3:4b
CODING_MODEL=qwen2.5-coder:7b
FAST_MODEL=llama3.2:3b
QUICK_CHAT_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
XAI_API_KEY=
XAI_MODEL=grok-2-latest
COHERE_API_KEY=
COHERE_MODEL=command-r-plus
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_SCHEMA_COLLECTION=insightflow_schema_memory
VECTOR_DB_ENABLED=true
VECTOR_DB_FALLBACK_JSON=true

DATABASE_PATH=./data/insightflow.db
DATA_DIR=./data
LOG_LEVEL=info
VERBOSE_LOGGING=false
LOCAL_NLP_ENABLED=true
AUTO_CHART_GENERATION=true
CORRELATION_ANALYSIS=true
OUTLIER_DETECTION=true
CHAT_HISTORY_ENABLED=true
SMARTCHART_ENABLED=true

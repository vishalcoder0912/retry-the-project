# AI Provider Configuration
# Choose one or more AI providers to enable

# Google Gemini AI
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434
# Available models: llama3.1, llama3.2, natural, codellama, mistral, etc.
OLLAMA_MODEL=llama3.2

# Server Configuration
NODE_ENV=development
PORT=3000

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your preferred API keys
# 3. For Ollama, ensure Ollama is running locally
# 4. The system will use available providers in fallback order: Ollama -> Gemini -> OpenAI -> Anthropic

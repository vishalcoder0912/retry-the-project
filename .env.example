# Copy this to .env and fill in your values

# Backend
PORT=3001
HOST=localhost
NODE_ENV=development
DATA_DIR=./data

# Google Gemini API (Primary AI)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API (Fallback Option)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude API (Fallback Option)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama Local AI
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat:7b

# Ollama Multi-Model Configuration (Manager + Dashboard + Chat + Embeddings)
OLLAMA_MANAGER_MODEL=qwen3:8b
OLLAMA_SCHEMA_MODEL=qwen3:8b
OLLAMA_DASHBOARD_MODEL=qwen3:4b
OLLAMA_DASHBOARD_CHAT_MODEL=qwen3:4b
OLLAMA_GENERAL_CHAT_MODEL=llama3.2:3b
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_FALLBACK_MODEL=qwen3:latest
OLLAMA_TIMEOUT_MS=4000
DASHBOARD_AI_TIMEOUT_MS=3000
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MAX_TOKENS=900
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=700

# Schema RAG Memory
SCHEMA_MEMORY_DIR=./data/schema-memory
RAG_MAX_ENTRIES=500

# AI Services Configuration
LOCAL_NLP_ENABLED=true
AI_PROVIDER_PRIORITY=gemini,openai,anthropic

# AI Service Settings
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# Frontend
VITE_API_BASE_URL=http://localhost:3001

# Python ML/Data Science service
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=30000
ML_ANALYTICS_CACHE_TTL_MS=600000
ML_ANALYTICS_CACHE_MAX_ENTRIES=500
MAX_JSON_BODY_BYTES=20971520

# Security (Production)
# CORS_ORIGIN=https://your-domain.com
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000


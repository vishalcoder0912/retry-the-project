# Copy this to .env and fill in your values

# Backend
PORT=3001
HOST=localhost
NODE_ENV=development
DATA_DIR=./data

# Google Gemini API (Primary AI)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API (Fallback Option)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude API (Fallback Option)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama Local AI
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
MAIN_ANALYST_MODEL=qwen3:8b
DASHBOARD_PLANNER_MODEL=qwen3:8b
CHATBOT_MODEL=qwen3:8b
KPI_VALIDATOR_MODEL=qwen3:4b
CHART_VALIDATOR_MODEL=qwen3:4b
FACT_CHECKER_MODEL=qwen3:4b
JSON_VALIDATOR_MODEL=qwen3:4b
FAST_MODEL=llama3.2:3b
QUICK_CHAT_MODEL=llama3.2:3b
CODING_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=nomic-embed-text:latest
RAG_EMBEDDING_MODEL=nomic-embed-text:latest

# Vector DB / Qdrant memory layer
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_SCHEMA_COLLECTION=insightflow_schema_memory
QDRANT_PDF_COLLECTION=insightflow_pdf_rag
QDRANT_PDF_CHUNKS_COLLECTION=insightflow_pdf_chunks
QDRANT_PDF_SUMMARIES_COLLECTION=insightflow_pdf_summaries
QDRANT_PDF_TABLES_COLLECTION=insightflow_pdf_tables
VECTOR_DB_ENABLED=true
VECTOR_DB_FALLBACK_JSON=true
FAST_ANALYTICS_ENGINE=duckdb
LARGE_DATASET_ROW_THRESHOLD=50000
ML_SERVICE_MAX_ROWS=1000000
ML_SERVICE_TIMEOUT_MS=10000
DASHBOARD_LLM_TIMEOUT_MS=25000
ENABLE_AIRLLM_DEEP_REASONER=false
AIRLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
AIRLLM_COMPRESSION=4bit

# Ollama Multi-Model Configuration (Manager + Dashboard + Chat + Embeddings)
OLLAMA_MANAGER_MODEL=qwen3:8b
OLLAMA_SCHEMA_MODEL=qwen3:8b
OLLAMA_DASHBOARD_MODEL=qwen3:4b
OLLAMA_DASHBOARD_CHAT_MODEL=qwen3:4b
OLLAMA_GENERAL_CHAT_MODEL=llama3.2:3b
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_FALLBACK_MODEL=qwen3:latest
OLLAMA_TIMEOUT_MS=4000
DASHBOARD_AI_TIMEOUT_MS=3000
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MAX_TOKENS=900
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=700

# Schema RAG Memory
SCHEMA_MEMORY_DIR=./data/schema-memory
RAG_MAX_ENTRIES=500

# AI Services Configuration
LOCAL_NLP_ENABLED=true
AI_PROVIDER_PRIORITY=gemini,openai,anthropic

# AI Service Settings
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# Frontend
VITE_API_BASE_URL=http://localhost:3001

# Python ML/Data Science service
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=30000
ML_ANALYTICS_CACHE_TTL_MS=600000
ML_ANALYTICS_CACHE_MAX_ENTRIES=500
MAX_JSON_BODY_BYTES=20971520

# PDF Intelligence
PDF_INTELLIGENCE_ENABLED=true
PDF_PIPELINE_MODE=separate
PDF_ASYNC_PROCESSING=true
PDF_MAX_FILE_SIZE_MB=500
PDF_MAX_PAGES=2000
PDF_PROCESSING_BATCH_SIZE=5
PDF_OCR_ENABLED=true
PDF_FORCE_OCR_DEFAULT=false
PDF_OCR_ENGINE=tesseract
PDF_RENDER_DPI=220
PDF_OCR_RENDER_DPI=250
PDF_CHUNK_SIZE=1000
PDF_CHUNK_OVERLAP=150
PDF_VECTOR_BATCH_SIZE=64
PDF_PROCESSING_TIMEOUT_MS=600000
PDF_INTELLIGENCE_TIMEOUT_MS=120000
PDF_ENABLE_CACHE=true
PDF_ENABLE_PAGE_CACHE=true
PDF_ENABLE_INCREMENTAL_INDEXING=true
PDF_ENABLE_PARTIAL_QA=true
PDF_EXPLAINER_MODEL=qwen3:8b
PDF_SUMMARIZER_MODEL=qwen3:8b
PDF_FAST_MODEL=llama3.2:3b
PDF_VALIDATOR_MODEL=qwen3:4b
PDF_EMBEDDING_MODEL=nomic-embed-text:latest
DISABLE_TEXT_TABLE_CHARTS=true
MIN_TABLE_COLUMNS_FOR_CHART=2
MIN_ROWS_FOR_CHART=3
DISABLE_AUTO_FORCE_OCR_ON_QUERY=true

# Security (Production)
# CORS_ORIGIN=https://your-domain.com
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000


{
  "name": "insightflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:frontend": "npm run dev --workspace=@insightflow/frontend",
    "dev:backend": "npm run dev --workspace=@insightflow/backend",
    "dev:all": "npm run dev:backend & npm run dev:frontend",
    "build": "npm run build --workspace=@insightflow/frontend",
    "build:frontend": "npm run build --workspace=@insightflow/frontend",
    "build:backend": "npm run build --workspace=@insightflow/backend",
    "lint": "npm run lint --workspace=@insightflow/frontend",
    "test": "npm run test --workspace=@insightflow/frontend"
  }
}

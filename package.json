{
  "name": "insightflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/shared-analytics"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --names backend,frontend,ml --prefix-colors cyan,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ml\"",
    "dev:all": "npm run dev",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:ml": "python -m uvicorn app:app --host 127.0.0.1 --port 8000 --workers 1 --app-dir apps/ml-service",
    "build": "npm run build -w apps/frontend",
    "build:frontend": "npm run build -w apps/frontend",
    "build:backend": "npm run build -w apps/backend",
    "export:ai-safe": "node scripts/export-ai-safe.js",
    "export:onefile": "node scripts/export-full-codebase-one-file.js",
    "export:codebase": "node scripts/generate-codebase-export.mjs",
    "lint": "npm run lint -w apps/frontend",
    "test": "npm run test -w apps/frontend",
    "test:backend": "npm run test:run -w apps/backend",
    "test:frontend": "npm run test -w apps/frontend",
    "test:e2e": "npx playwright test",
    "qa:report": "node tools/qa/generate-final-qa-report.mjs",
    "test:ai": "vitest run -w apps/backend apps/backend/src/__tests__/ai-provider-router.test.js",
    "test:rag": "vitest run -w apps/backend apps/backend/src/__tests__/rag-retrieval.test.js",
    "test:guardian": "vitest run -w apps/backend apps/backend/src/__tests__/dashboard-guardian.test.js",
    "test:insightflow-api": "node scripts/verify-insightflow-backend.mjs",
    "doctor": "npx react-doctor@latest",
    "audit:code": "node scripts/audit-codebase.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "react-doctor": "^0.2.13"
  },
  "dependencies": {
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "react-simple-maps": "^3.0.0",
    "topojson-client": "^3.1.0"
  }
}
